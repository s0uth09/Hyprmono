# Swaylock Monochrome Configuration
daemonize
show-failed-attempts
clock
screenshot
effect-blur=15x15
effect-vignette=1:1
color=11111180
font="JetBrainsMono Nerd Font"
indicator
indicator-radius=200
indicator-thickness=20

# Palette
$bg = 111111
$fg = eeeeee
$gray = 444444
$white = ffffff
$mid = 888888

line-color=$bg
ring-color=$gray
inside-color=$bg
key-hl-color=$white
separator-color=00000000
text-color=$fg
text-caps-lock-color=""

line-ver-color=$white
ring-ver-color=$white
inside-ver-color=$bg
text-ver-color=$fg

ring-wrong-color=$mid
text-wrong-color=$mid
inside-wrong-color=$bg

inside-clear-color=$bg
text-clear-color=$fg
ring-clear-color=$mid
line-clear-color=$bg
line-wrong-color=$bg
bs-hl-color=$mid

grace=2
grace-no-mouse
grace-no-touch
datestr=%a, %B %e
timestr=%I:%M %p
fade-in=0.3
ignore-empty-password
