{
    "custom/theme": {
        "format": "{0}",
        "rotate": 0,
        "tooltip-format": "\udb81\udfe1 Switch theme",
        "on-click": "themeswitch -n",
        "on-click-right": "themeswitch -p",
        "on-click-middle": "sleep 0.1 && themeselect", 
        "interval": 86400,
        "tooltip": true
    }
}