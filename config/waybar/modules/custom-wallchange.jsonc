{
    "custom/wallchange": {
        "format": "\udb80\udd8a {0}",
        "rotate": 0,
        "tooltip-format": "\udb80\udd8a Switch wallpaper",
        "on-click": "wallpaper -n",
        "on-click-right": "wallpaper -p",
        "on-click-middle": "wallpaper --select", 
        "interval": 86400,
        "tooltip": true
    }
}